# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/askclerio"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Corsair
CORSAIR_KEK=your_32_character_encryption_key_here

# MCP Key Encryption
# 64-character hex string (32 bytes) used to encrypt tenant MCP key secrets at rest.
# Generate with: openssl rand -hex 32
TENANT_KEY_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP Server (Corsair)
# Internal token shared between Next.js chat route and the MCP Express server.
# The MCP server rejects requests without a matching x-mcp-internal-token header.
# Generate with: openssl rand -base64 32
MCP_INTERNAL_TOKEN=your_mcp_internal_token_here
# Optional: override MCP server URL (defaults to http://localhost:3001/mcp)
# MCP_URL=http://localhost:3001/mcp

# AI Tool Approval Security
# Server-side secret for signing tool approval tokens (experimental_toolApprovalSecret).
# Used to cryptographically verify that irreversible tool executions (e.g., send_email)
# were genuinely approved through the server's approval flow, not forged by a modified client.
# Generate with: openssl rand -base64 32
TOOL_APPROVAL_SECRET=your_tool_approval_secret_here

# OpenAI Configuration
# The model used for chat and tool-calling. Change without redeploying code.
# Examples: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
